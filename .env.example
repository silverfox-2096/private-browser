# Copy this file to .env and fill in the three values below.
# NEVER commit .env -- it holds your VPN private key. (.gitignore excludes it.)
# After creating it:  chmod 600 .env

# WireGuard private key -- from your provider's config file, [Interface] PrivateKey
WIREGUARD_PRIVATE_KEY=

# WireGuard address -- from the same config, [Interface] Address (usually a /32)
WIREGUARD_ADDRESSES=10.2.0.2/32

# Password for the VNC web UI. Note: VNC caps this at 8 characters (RFB
# protocol truncates the rest), so it is weak by design -- acceptable here
# only because the UI is bound to localhost. Set any 8-character value.
VNC_PASSWORD=
